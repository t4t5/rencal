{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "renCal",
  "version": "0.0.1",
  "identifier": "org.ren.rencal",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "renCal",
        "width": 1200,
        "height": 800,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": ["ics"],
        "mimeType": "text/calendar",
        "name": "iCalendar",
        "description": "iCalendar file"
      }
    ],
    "resources": [
      "providers/caldir-provider-google",
      "providers/caldir-provider-icloud",
      "providers/caldir-provider-outlook",
      "providers/caldir-provider-caldav",
      "providers/caldir-provider-webcal",
      "icons/128x128.png"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libnotify-bin"],
        "files": {
          "/usr/bin/rencal-notifierd": "target/release/rencal-notifierd",
          "/usr/lib/systemd/user/rencal-notifierd.service": "notifierd/rencal-notifierd.service"
        }
      },
      "rpm": {
        "depends": ["libnotify"],
        "files": {
          "/usr/bin/rencal-notifierd": "target/release/rencal-notifierd",
          "/usr/lib/systemd/user/rencal-notifierd.service": "notifierd/rencal-notifierd.service"
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERCNjMxMDEwOTE5RTk1MzYKUldRMmxaNlJFQkJqMjh6dDRyUzBRTDU4dnlMQlJjb0xtbGJ0ZG9hcnpWWDBNayszV0hHdGdiak0K",
      "endpoints": ["https://github.com/t4t5/rencal/releases/latest/download/latest.json"]
    }
  }
}
