{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rencal",
  "version": "0.1.0",
  "identifier": "rencal",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:rencal.db"]
    }
  },
  "app": {
    "windows": [
      {
        "title": "renCal",
        "width": 1200,
        "height": 800,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "providers/caldir-provider-google",
      "providers/caldir-provider-icloud",
      "icons/128x128.png"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
