---
import "../styles/index.css"

import BaseLayout from "../layouts/BaseLayout.astro"
import CopyButton from "../components/CopyButton.astro"
import InstallPlatform from "../components/download/InstallPlatform.astro"
import InstallRow from "../components/download/InstallRow.astro"
import type { GitHubRelease } from "../lib/github"
import { getLatestRelease } from "../lib/github"
import AppleLogo from "../icons/apple.astro"
import DownloadIcon from "../icons/download.astro"
import LinuxLogo from "../icons/linux.astro"
import { site } from "../site"

const releasesUrl = "https://github.com/t4t5/rencal/releases"
const aurCommand = "yay -S rencal-bin"

let latestRelease: GitHubRelease | undefined
try {
  latestRelease = await getLatestRelease()
} catch (error) {
  // A transient API outage must not prevent the static site from deploying.
  // Download links fall back to the public releases page in this case.
  console.warn("Could not fetch the latest renCal release; using download fallbacks.", error)
}

const assetUrl = (pattern: RegExp) =>
  latestRelease?.assets.find((asset) => pattern.test(asset.name))?.browser_download_url

interface DownloadRow {
  label: string
  architecture: string
  href?: string
}

const linuxDownloads: DownloadRow[] = [
  { label: "Debian (deb)", architecture: "x64", href: assetUrl(/_amd64\.deb$/) },
  { label: "Red Hat / Fedora (rpm)", architecture: "x64", href: assetUrl(/\.x86_64\.rpm$/) },
  { label: "AppImage", architecture: "x64", href: assetUrl(/_amd64\.AppImage$/) },
]

const macDownloads: DownloadRow[] = [
  { label: "Installer (dmg)", architecture: "Apple Silicon", href: assetUrl(/_aarch64\.dmg$/) },
]

const dateFormat = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
})

const releaseDate = latestRelease?.published_at
  ? dateFormat.format(new Date(latestRelease.published_at))
  : null

if (latestRelease) {
  const missing = [...linuxDownloads, ...macDownloads].filter((row) => !row.href)
  if (missing.length > 0) {
    throw new Error(
      `Latest GitHub release ${latestRelease.tag_name} is missing download assets: ${missing
        .map((row) => row.label)
        .join(", ")}`,
    )
  }
}
---

<BaseLayout
  title={`Download - ${site.title}`}
  description={`Download the latest version of ${site.title}.`}
>
  <div class="flex flex-col items-center">
    <div class="flex flex-col items-center gap-4">
      <div
        class="w-[195px] h-[195px] bg-contain"
        style={{
          backgroundImage: "url(/app-icon.png)",
        }}
      >
      </div>

      <a
        href={macDownloads[0]?.href ?? releasesUrl}
        hidden
        data-platform-mac
        class="button-outline text-[17px] flex items-center py-3! px-4! gap-3"
      >
        <DownloadIcon class="h-4 w-4 relative top-[-1px]" />
        <span>Download renCal for Mac</span>
      </a>

      <h2 class="text-2xl" hidden data-platform-linux>Download renCal</h2>

      <p>
        <span hidden data-platform-mac>Apple Silicon •</span>

        {latestRelease && <span>Version {latestRelease.tag_name.replace(/^v/, "")}</span>}

        {releaseDate && <span class="text-muted">• {releaseDate}</span>}
      </p>
    </div>

    <section class="mx-auto flex w-full max-w-4xl flex-col gap-4 px-6 pt-10 md:px-10 md:pt-18">
      <div class="flex flex-col gap-3" hidden data-platform-mac>
        <h2 class="text-muted!">Other platforms:</h2>
      </div>

      <div class="flex flex-col gap-8" data-platform-sections>
        <InstallPlatform platform="linux" label="Linux">
          <LinuxLogo slot="icon" class="h-5 w-5" />

          <InstallRow label="Arch / Omarchy (AUR)">
            <CopyButton
              command={aurCommand}
              label="Copy the renCal AUR install command"
              showCommand
            />
          </InstallRow>

          {
            linuxDownloads.map((row) => (
              <InstallRow label={row.label}>
                <a
                  href={row.href ?? releasesUrl}
                  aria-label={`Download renCal for Linux, ${row.label}, ${row.architecture}`}
                  class="flex items-center gap-2 bg-white/5 px-4 py-2 text-sm hover:bg-white/10"
                >
                  <DownloadIcon class="h-4 w-4" />
                  {row.architecture}
                </a>
              </InstallRow>
            ))
          }
        </InstallPlatform>

        <InstallPlatform platform="macos" label="Mac">
          <AppleLogo slot="icon" class="h-5 w-5" />

          {
            macDownloads.map((row) => (
              <InstallRow label={row.label}>
                <a
                  href={row.href ?? releasesUrl}
                  aria-label={`Download renCal for macOS, ${row.architecture}`}
                  class="flex items-center gap-2 bg-white/5 px-4 py-2 text-sm hover:bg-white/10"
                >
                  <DownloadIcon class="h-4 w-4" />
                  {row.architecture}
                </a>
              </InstallRow>
            ))
          }
        </InstallPlatform>
      </div>
    </section>

    <script is:inline>
      const userAgent = navigator.userAgent
      const isTouchAppleDevice = /iPhone|iPad|iPod/.test(userAgent) || navigator.maxTouchPoints > 1
      const isMac = /Macintosh|Mac OS X/.test(userAgent) && !isTouchAppleDevice
      const isLinux = /Linux/.test(userAgent) && !/Android/.test(userAgent)

      // Linux comes first in the markup; move the Mac section up for Mac visitors.
      if (isMac) {
        for (const element of document.querySelectorAll("[data-platform-mac]")) {
          element.removeAttribute("hidden")
        }

        const sections = document.querySelector("[data-platform-sections]")
        const macSection = document.querySelector('[data-platform="macos"]')
        if (sections && macSection) sections.prepend(macSection)
      }

      if (isLinux) {
        for (const element of document.querySelectorAll("[data-platform-linux]")) {
          element.removeAttribute("hidden")
        }
      }
    </script>
  </div>
</BaseLayout>
