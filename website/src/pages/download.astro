---
import "../styles/index.css"

import AurCommand from "../components/download/AurCommand.astro"
import DownloadRow from "../components/download/DownloadRow.astro"
import BaseLayout from "../layouts/BaseLayout.astro"
import type { GitHubRelease, GitHubReleaseAsset } from "../lib/github"
import { getLatestRelease } from "../lib/github"
import AppleLogo from "../icons/apple.astro"
import LinuxLogo from "../icons/linux.astro"
import OmarchyLogo from "../icons/omarchy.astro"
import { site } from "../site"

type PlatformKey = "linux" | "macos"
type DownloadKey = "deb" | "rpm" | "appimage" | "dmg"

interface DownloadDefinition {
  key: DownloadKey
  label: string
  description: string
  architecture: string
  accessiblePlatform: string
  pattern: RegExp
  required: boolean
  badge?: string
  note?: string
}

interface PlatformDefinition {
  key: PlatformKey
  rows: DownloadDefinition[]
}

interface ResolvedDownload extends DownloadDefinition {
  asset?: GitHubReleaseAsset
}

const appImageNote =
  "Background reminders require renCal to remain running. Native packages install the background reminder service."

// This is the single artifact table. Add future formats here, marking them
// optional when a release is allowed to omit them.
const platforms: PlatformDefinition[] = [
  {
    key: "linux",
    rows: [
      {
        key: "deb",
        label: "Debian / Ubuntu",
        description: "Native package for Debian, Ubuntu, and related distributions.",
        architecture: "x86-64 · .deb",
        accessiblePlatform: "Debian or Ubuntu",
        pattern: /_amd64\.deb$/,
        required: true,
        badge: "Recommended",
      },
      {
        key: "rpm",
        label: "Red Hat / Fedora / openSUSE",
        description: "Native package for RPM-based distributions.",
        architecture: "x86-64 · .rpm",
        accessiblePlatform: "Red Hat, Fedora, or openSUSE",
        pattern: /\.x86_64\.rpm$/,
        required: true,
      },
      {
        key: "appimage",
        label: "Other Linux",
        description: "Run renCal without installing a system package.",
        architecture: "x86-64 · AppImage",
        accessiblePlatform: "other Linux distributions",
        pattern: /_amd64\.AppImage$/,
        required: true,
        badge: "Portable",
        note: appImageNote,
      },
    ],
  },
  {
    key: "macos",
    rows: [
      {
        key: "dmg",
        label: "macOS installer",
        description: "Installer for Macs with Apple silicon.",
        architecture: "Apple silicon · .dmg",
        accessiblePlatform: "macOS",
        pattern: /_aarch64\.dmg$/,
        required: true,
      },
    ],
  },
]

let latestRelease: GitHubRelease | undefined
try {
  latestRelease = await getLatestRelease()
} catch (error) {
  // A transient API outage must not prevent the static site from deploying.
  // Artifact links below fall back to the public releases page in this case.
  console.warn("Could not fetch the latest renCal release; using download fallbacks.", error)
}

const resolvedPlatforms = platforms.map((platform) => ({
  ...platform,
  rows: platform.rows.map<ResolvedDownload>((row) => ({
    ...row,
    asset: latestRelease?.assets.find((asset) => row.pattern.test(asset.name)),
  })),
}))

if (latestRelease) {
  const missingRequired = resolvedPlatforms.flatMap((platform) =>
    platform.rows.filter((row) => row.required && !row.asset),
  )

  if (missingRequired.length > 0) {
    const details = missingRequired
      .map((row) => `${row.label} (${row.pattern.toString()})`)
      .join(", ")
    throw new Error(
      `Latest GitHub release ${latestRelease.tag_name} is missing required download assets: ${details}`,
    )
  }
}

const linuxRows = resolvedPlatforms.find((platform) => platform.key === "linux")?.rows ?? []
const macRows = resolvedPlatforms.find((platform) => platform.key === "macos")?.rows ?? []
const debDownload = linuxRows.find((row) => row.key === "deb")
const rpmDownload = linuxRows.find((row) => row.key === "rpm")
const appImageDownload = linuxRows.find((row) => row.key === "appimage")
const macDownload = macRows.find((row) => row.key === "dmg")
const version = latestRelease?.tag_name.replace(/^v/, "")
---

<BaseLayout
  title={`Download · ${site.title}`}
  description={`Download the latest version of ${site.title} for Linux and macOS.`}
>
  <section class="mx-auto flex w-full max-w-5xl flex-col gap-10 px-6 pt-6 md:px-10 md:pt-10">
    <div class="flex max-w-3xl flex-col gap-4">
      <h2 class="text-3xl md:text-4xl">Download renCal</h2>
      <p class="max-w-2xl text-pretty leading-relaxed">
        Install the latest renCal release directly, or choose a package for another supported
        platform below.
      </p>
      {
        latestRelease ? (
          <p class="text-sm">
            Latest version:{" "}
            <a class="text-primary hover:underline" href="/releases">
              {latestRelease.tag_name}
            </a>
          </p>
        ) : (
          <p class="border-l-2 border-primary pl-3 text-sm leading-relaxed">
            Direct download details are temporarily unavailable. The links below will take you to
            GitHub Releases instead.
          </p>
        )
      }
    </div>

    <section
      hidden
      data-platform-hero="linux"
      aria-labelledby="linux-download-heading"
      class="flex flex-col gap-4 border-y border-separator py-8"
    >
      <div class="flex items-center gap-3">
        <LinuxLogo class="h-6 w-6" />
        <h3 id="linux-download-heading" class="text-2xl">Choose your Linux distribution</h3>
      </div>
      <div class="grid gap-3 md:grid-cols-2">
        {debDownload && <DownloadRow {...debDownload} version={version} featured />}
        {rpmDownload && <DownloadRow {...rpmDownload} version={version} featured />}
        <AurCommand featured />
        {appImageDownload && <DownloadRow {...appImageDownload} version={version} featured />}
      </div>
    </section>

    <section
      hidden
      data-platform-hero="macos"
      aria-labelledby="macos-download-heading"
      class="flex flex-col gap-4 border-y border-separator py-8"
    >
      <div class="flex items-center gap-3">
        <AppleLogo class="h-6 w-6" />
        <h3 id="macos-download-heading" class="text-2xl">Download for macOS</h3>
      </div>
      {macDownload && <DownloadRow {...macDownload} version={version} featured />}
    </section>

    <section class="flex flex-col gap-6" aria-labelledby="all-downloads-heading">
      <h3 id="all-downloads-heading" class="text-2xl md:text-3xl">All downloads</h3>

      <div class="flex flex-col gap-4" aria-labelledby="linux-heading">
        <div class="flex items-center gap-3">
          <LinuxLogo class="h-5 w-5" />
          <h4 id="linux-heading" class="text-xl">Linux</h4>
        </div>
        <div class="flex flex-col gap-3">
          {linuxRows.map((download) => <DownloadRow {...download} version={version} />)}
        </div>
      </div>

      <div class="flex flex-col gap-4 border-t border-separator pt-6" aria-labelledby="aur-heading">
        <div class="flex items-center gap-3">
          <OmarchyLogo class="h-5 w-5" />
          <h4 id="aur-heading" class="text-xl">Omarchy / Arch Linux</h4>
        </div>
        <AurCommand />
      </div>

      <div
        class="flex flex-col gap-4 border-t border-separator pt-6"
        aria-labelledby="macos-heading"
      >
        <div class="flex items-center gap-3">
          <AppleLogo class="h-5 w-5" />
          <h4 id="macos-heading" class="text-xl">macOS</h4>
        </div>
        {macRows.map((download) => <DownloadRow {...download} version={version} />)}
      </div>
    </section>
  </section>

  <script is:inline>
    const userAgent = navigator.userAgent
    const isTouchAppleDevice = /iPhone|iPad|iPod/.test(userAgent) || navigator.maxTouchPoints > 1
    const isDesktopMac = /Macintosh|Mac OS X/.test(userAgent) && !isTouchAppleDevice
    const isDesktopLinux = /Linux/.test(userAgent) && !/Android/.test(userAgent)
    const detectedPlatform = isDesktopMac ? "macos" : isDesktopLinux ? "linux" : null

    if (detectedPlatform) {
      document
        .querySelector(`[data-platform-hero="${detectedPlatform}"]`)
        ?.removeAttribute("hidden")
    }

    function fallbackCopy(text) {
      const input = document.createElement("textarea")
      input.value = text
      input.setAttribute("readonly", "")
      input.style.position = "fixed"
      input.style.opacity = "0"
      document.body.append(input)
      input.select()
      const copied = document.execCommand("copy")
      input.remove()
      return copied
    }

    for (const button of document.querySelectorAll("[data-copy-command]")) {
      button.addEventListener("click", async () => {
        const command = button.getAttribute("data-copy-command")
        if (!command) return

        let copied = false
        try {
          if (navigator.clipboard) {
            await navigator.clipboard.writeText(command)
            copied = true
          } else {
            copied = fallbackCopy(command)
          }
        } catch {
          copied = fallbackCopy(command)
        }

        button.textContent = copied ? "Copied" : "Copy failed"
        window.setTimeout(() => {
          button.textContent = "Copy"
        }, 1800)
      })
    }
  </script>
</BaseLayout>
