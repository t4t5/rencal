---
import OmarchyLogo from "../../icons/omarchy.astro"
import LinuxLogo from "../../icons/linux.astro"
---

<div class="text-center flex flex-col items-center gap-7 border-b border-b-separator px-4">
  <h2 class="uppercase text-[30px] md:text-[40px] leading-tight pt-10 md:pt-6 text-pretty">
    A modern open-source calendar
  </h2>

  <div class="flex gap-3 items-center">
    <OmarchyLogo class="h-4" />
    <LinuxLogo class="h-4" />
    <p>Built for Omarchy + Linux</p>
  </div>

  <div class="flex gap-5">
    <a href="/docs/installation">
      <button class="primary">Install</button>
    </a>

    <a href="/docs/calendar-data">
      <button>Docs</button>
    </a>
  </div>

  <div
    class="relative mt-8 w-[calc(100%+1rem)] self-start overflow-hidden border border-separator border-b-0 border-r-0 rounded-none rounded-tl-md md:mx-0 md:w-full md:max-w-5xl md:self-auto md:rounded-t-md md:border-x"
  >
    <img
      src="/demo-poster.avif"
      alt="renCal screenshot"
      width="960"
      height="500"
      class="w-[180vw] max-w-none rounded-none md:w-full md:rounded-lg"
    />
    <video
      class="absolute inset-0 h-full w-[180vw] max-w-none rounded-none object-cover object-left-top opacity-0 transition-opacity md:w-full md:rounded-lg"
      autoplay
      loop
      muted
      playsinline
      preload="metadata"
      aria-label="renCal demo"
      oncanplay="this.classList.remove('opacity-0')"
    >
      <source src="/demo.mp4" type="video/mp4" />
    </video>
  </div>
</div>
