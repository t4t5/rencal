---
import Logo from "../../icons/rencal-logo.astro"
import GitHubLogo from "../../icons/github.astro"
import MenuBars from "../MenuBars.astro"
---

<header class="relative px-6 md:px-10 py-4 flex justify-between items-center gap-7">
  <a href="/">
    <h1 aria-label="renCal" class="relative top-[-2px]">
      <Logo class="h-[51px]" />
      <span class="sr-only">renCal</span>
    </h1>
  </a>

  <button
    id="menu-toggle"
    type="button"
    class="sm:hidden p-2 -mr-2 -mt-1 text-foreground bg-transparent! outline-none"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="site-nav"
  >
    <MenuBars />
  </button>

  <nav
    id="site-nav"
    class="hidden absolute top-full inset-x-0 z-50 flex-col gap-5 px-6 py-5 bg-background border-b border-white/10 uppercase text-foreground [&>a:hover]:underline sm:static sm:flex sm:flex-row sm:items-center sm:gap-7 sm:p-0 sm:border-none"
  >
    <a href="/download">Download</a>
    <a href="/docs/installation">Docs</a>
    <a href="/changelog">Changelog</a>
    <a href="https://github.com/t4t5/rencal" target="_blank" aria-label="GitHub repo">
      <GitHubLogo class="w-6" />
    </a>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle")
  const nav = document.getElementById("site-nav")

  toggle?.addEventListener("click", () => {
    const isOpen = nav?.classList.toggle("hidden") === false
    nav?.classList.toggle("flex", isOpen)
    toggle.setAttribute("aria-expanded", String(isOpen))
    toggle.setAttribute("aria-label", isOpen ? "Close menu" : "Open menu")
  })
</script>
