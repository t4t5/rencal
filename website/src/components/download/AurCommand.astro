---
interface Props {
  featured?: boolean
}

const { featured = false } = Astro.props
const command = "yay -S rencal-bin"
---

<div
  class:list={[
    "flex flex-col gap-3 border border-separator bg-white/[0.025] p-4",
    { "p-5 md:p-6": featured },
  ]}
>
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div class="flex flex-col gap-1.5">
      <h4 class:list={["text-base", { "text-lg": featured }]}>Arch / Omarchy</h4>
      <p class="text-sm">Install the AUR package with your preferred helper.</p>
    </div>
  </div>

  <div class="flex items-center justify-between gap-3 bg-black/30 px-3 py-2.5">
    <code class="overflow-x-auto text-sm text-foreground">{command}</code>
    <button
      type="button"
      class="shrink-0 px-3 py-1.5 text-xs"
      data-copy-command={command}
      aria-label="Copy the renCal AUR install command"
    >
      Copy
    </button>
  </div>
</div>
