---
import type { GitHubReleaseAsset } from "../../lib/github"

interface Props {
  label: string
  description: string
  architecture: string
  accessiblePlatform: string
  asset?: GitHubReleaseAsset
  version?: string
  badge?: string
  note?: string
  featured?: boolean
}

const {
  label,
  description,
  architecture,
  accessiblePlatform,
  asset,
  version,
  badge,
  note,
  featured = false,
} = Astro.props

const releasesUrl = "https://github.com/t4t5/rencal/releases"
const href = asset?.browser_download_url ?? releasesUrl
const size = asset
  ? new Intl.NumberFormat("en-US", { maximumFractionDigits: 1 }).format(asset.size / 1_000_000)
  : null
const accessibleLabel =
  asset && version
    ? `Download renCal ${version} for ${accessiblePlatform}, ${architecture}.`
    : `View GitHub Releases for renCal for ${accessiblePlatform}, ${architecture}.`
---

<div
  class:list={[
    "flex flex-col gap-4 border border-separator bg-white/[0.025] p-4 sm:flex-row sm:items-center sm:justify-between",
    { "p-5 md:p-6": featured },
  ]}
>
  <div class="flex min-w-0 flex-col gap-1.5">
    <div class="flex flex-wrap items-center gap-2.5">
      <h4 class:list={["text-base", { "text-lg": featured }]}>{label}</h4>
      {
        badge && (
          <span class="border border-primary px-2 py-0.5 text-[0.65rem] tracking-wide text-primary uppercase">
            {badge}
          </span>
        )
      }
    </div>
    <p class="text-sm text-pretty">{description}</p>
    <p class="text-xs text-muted opacity-70">
      {architecture}{size ? ` · ${size} MB` : ""}
    </p>
    {note && <p class="max-w-2xl text-xs leading-relaxed text-muted opacity-70">{note}</p>}
  </div>

  <a
    href={href}
    aria-label={accessibleLabel}
    class:list={[
      "shrink-0 self-start bg-primary px-4 py-2 text-sm text-[#131313] uppercase hover:bg-[#ff7b33] sm:self-center",
      { "px-5 py-3 text-base": featured },
    ]}
  >
    {asset ? "Download" : "Download from GitHub Releases"}
  </a>
</div>
